# All env vars are prefixed with FLOWFRAME_
# Copy this file to .env and fill in real values.

FLOWFRAME_APP_NAME=FlowFrame
FLOWFRAME_ENVIRONMENT=development
FLOWFRAME_DEBUG=true

# SQLite (default, no setup required)
FLOWFRAME_DATABASE_URL=sqlite+aiosqlite:///./flowframe.db

# PostgreSQL example
# FLOWFRAME_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/flowframe

FLOWFRAME_DATA_DIR=.data
FLOWFRAME_CORS_ORIGINS=["http://localhost:5173"]
FLOWFRAME_MAX_UPLOAD_SIZE_MB=100

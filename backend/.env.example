# All env vars are prefixed with CIAREN_
# Copy this file to .env and fill in real values.

CIAREN_ENVIRONMENT=development
CIAREN_DEBUG=true

# SQLite (default, no setup required)
CIAREN_DATABASE_URL=sqlite+aiosqlite:///./ciaren.db

# PostgreSQL example
# CIAREN_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ciaren

CIAREN_DATA_DIR=.data
CIAREN_CORS_ORIGINS=["http://localhost:5173"]
CIAREN_MAX_UPLOAD_SIZE_MB=100

        "y": 0
      },
      "config": {
        "model_type": "kmeans",
        "feature_columns": [
          "area",
          "bedrooms",
          "age",
          "distance_to_city",
          "price"
        ],
        "hyperparameters": {
          "n_clusters": 4
        },
        "seed": 19
      }
    }
  ],
  "edges": [

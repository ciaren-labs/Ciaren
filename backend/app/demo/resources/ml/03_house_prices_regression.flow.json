      "type": "mlPredict",
      "position": {
        "x": 750,
        "y": 0
      },
      "config": {
        "output_column": "prediction"
      }
    },
    {
      "id": "evaluate",
      "type": "mlEvaluate",
      "position": {
        "x": 1000,
        "y": 0
      },
      "config": {
        "task_type": "regression",
        "target_column": "price",
        "prediction_column": "prediction"
      }
    },
    {
      "id": "out_metrics",
      "type": "fileOutput",
      "position": {
        "x": 1250,
        "y": 0
      },
      "config": {
        "format": "csv",
        "dataset_name": "house_price_metrics"
      }
    }
  ],
  "edges": [
    {
      "source": "in_houses",
      "target": "split"
    },
    {
      "source": "split",
      "target": "train",
      "sourceHandle": "train",
      "targetHandle": "in"
    },
    {

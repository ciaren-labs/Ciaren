    },
    {
      "id": "split",
      "type": "trainTestSplit",
      "position": {
        "x": 250,
        "y": 0
      },
      "config": {
        "test_size": 0.25,
        "seed": 42
      }
    },
    {
      "id": "train",
      "type": "mlTrainRegressor",
      "position": {
        "x": 500,
        "y": -60
      },
      "config": {

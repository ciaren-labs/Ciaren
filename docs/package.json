{
  "name": "ciaren-docs",
  "version": "0.2.0",
  "description": "User-facing documentation for Ciaren data and ML workflow builder",
  "type": "module",
  "private": true,
  "scripts": {
    "sync-changelog": "node ./scripts/sync-changelog.js",
    "predev": "npm run sync-changelog",
    "dev": "vitepress dev .",
    "prebuild": "npm run sync-changelog",
    "build": "vitepress build .",
    "preview": "vitepress preview .",
    "test": "npm run lint && npm run build && npm run test:build && npm run test:links",
    "test:build": "node ./scripts/test-build.js",
    "test:links": "node ./scripts/check-links.js",
    "search:build": "node ./scripts/build-search.js",
    "lint": "markdownlint '**/*.md' --ignore node_modules --ignore '.vitepress'",
    "format": "prettier --write '**/*.md' --prose-wrap always"
  },
  "dependencies": {
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "vitepress": "^1.1.4",
    "typescript": "^6.0.3",
    "markdownlint-cli": "^0.49.1",
    "prettier": "^3.9.5",
    "vite": "^8.1.4"
  }
}

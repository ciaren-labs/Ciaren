{
  "name": "flowframe-docs",
  "version": "0.1.0",
  "description": "User-facing documentation for FlowFrame data and ML workflow builder",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vitepress dev .",
    "build": "vitepress build .",
    "preview": "vitepress preview .",
    "test": "npm run lint && npm run build && npm run test:build && npm run test:links",
    "test:build": "node ./scripts/test-build.js",
    "test:links": "node ./scripts/check-links.js",
    "search:build": "node ./scripts/build-search.js",
    "lint": "markdownlint '**/*.md' --ignore node_modules --ignore '.vitepress'",
    "format": "prettier --write '**/*.md' --prose-wrap always"
  },
  "dependencies": {
    "vue": "^3.4.19"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "vitepress": "^1.1.4",
    "typescript": "^6.0.3",
    "markdownlint-cli": "^0.49.0",
    "prettier": "^3.2.5",
    "vite": "^5.1.1"
  }
}
